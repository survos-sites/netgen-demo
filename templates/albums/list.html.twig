{% extends 'base.html.twig' %}

{% block title %}Albums{% endblock %}

{% block content %}
    <div class="container">
        <div class="row row-cards">
            {% for album in albums %}
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h3><a href="{{ path('app_albums_show', { slug: album.slug }) }}">{{ album.name }}</a></h3>
                            <p class="text-secondary">{{ album.description }}</p>
                            <p><span class="badge bg-blue-lt">{{ album.photos|length }} photos</span></p>
                            <a href="{{ path('app_story', { album: album.slug }) }}" class="btn btn-outline-primary btn-sm">View as Story</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
